# Токен основного бота от @BotFather (юзер-фейс)
BOT_TOKEN=your_bot_token_here

# Токен бота администрации (@adm_SleekHabitTracker_Bot) — туда летят
# уведомления о фидбэке и админ пишет ответы.
ADMIN_BOT_TOKEN=your_admin_bot_token_here

# Telegram user_id администратора (один человек). Уведомления о фидбэке
# шлются ему в DM от ADMIN_BOT_TOKEN.
ADMIN_CHAT_ID=385304518

# URL базы данных SQLite
DATABASE_URL="file:./database.db"
